### 4. RTOS integration ({{ rtos | upper }})

```c
#include "rtos_glue.h"

void main_task(void) {
{% if rtos == "freertos" %}
    edgeforge_rtos_start(tskIDLE_PRIORITY + 2);

    /* From any task: */
    edgeforge_infer_from_task(input_buf, output_buf);
{% elif rtos == "zephyr" %}
    edgeforge_rtos_start();

    /* From any thread: */
    edgeforge_infer_from_thread(input_buf, output_buf);
{% endif %}
}
```
